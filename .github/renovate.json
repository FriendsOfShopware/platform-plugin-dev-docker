{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions dependencies",
      "automerge": true
    }
  ],
  "github-actions": {
    "enabled": true,
    "managerFilePatterns": [
      "/^\\.github/workflows/[^/]+\\.ya?ml$/"
    ]
  }
}
